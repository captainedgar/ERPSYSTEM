{
  "name": "comercia-erp",
  "version": "0.2.0",
  "private": true,
  "packageManager": "npm@11.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "npm run test:e2e --workspace=apps/api",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm run db:generate --workspace=packages/database",
    "db:migrate": "npm run db:migrate --workspace=packages/database",
    "db:studio": "npm run db:studio --workspace=packages/database",
    "db:validate": "npm run db:validate --workspace=packages/database",
    "db:format": "npm run db:format --workspace=packages/database",
    "db:clear-sensitive": "npm run db:clear-sensitive --workspace=packages/database",
    "db:seed-platform-admin": "npm run db:seed-platform-admin --workspace=packages/database",
    "db:seed-saas-plans": "npm run db:seed-saas-plans --workspace=packages/database",
    "db:seed-demo": "npm run db:seed-demo --workspace=packages/database",
    "rbac:sync-company-roles": "dotenv -e .env -- node packages/database/scripts/sync-company-role-permissions.mjs",
    "billing:process-overdue": "npm run billing:process-overdue --workspace=packages/database"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "2.6.1",
    "typescript": "^5.9.3"
  }
}
