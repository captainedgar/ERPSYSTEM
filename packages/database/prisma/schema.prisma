  createdAt             DateTime                        @default(now())

  @@index([companyId, reportedAt(sort: Desc)])
  @@index([subscriptionInvoiceId, reportedAt(sort: Desc)])
  @@index([paymentLinkId, reportedAt(sort: Desc)])
  @@map("subscription_payment_reports")
}

model SubscriptionInvoiceSequence {
