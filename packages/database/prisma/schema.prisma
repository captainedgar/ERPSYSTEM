  updatedAt          DateTime               @updatedAt

  @@unique([companyId, documentType, documentNumber])
  @@index([companyId, saleId, documentType, status])
  @@index([companyId, status, createdAt(sort: Desc)])
  @@index([companyId, customerId, createdAt(sort: Desc)])
  @@index([companyId, saleId])
  @@map("internal_documents")
}

model InternalDocumentItem {
