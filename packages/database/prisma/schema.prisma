model ElectronicInvoice {
  id                 String                   @id @default(cuid())
  companyId          String
  branchId           String
  saleId             String?
  internalDocumentId String?
  customerId         String?
  documentType       ElectronicDocumentType   @default(INTERNAL_TEST)
  status             ElectronicInvoiceStatus  @default(DRAFT)
  fiscalNumber       String?
  providerDocumentId String?
  providerTrackId    String?
  payload            Json
  response           Json?
  errorMessage       String?
  sentAt             DateTime?
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  createdById        String
  company            Company                  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch             Branch                   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  sale               Sale?                    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  internalDocument   InternalDocument?        @relation(fields: [internalDocumentId], references: [id], onDelete: SetNull)
  customer           Customer?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
