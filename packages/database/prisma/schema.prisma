generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  CASHIER
  SELLER
  WAREHOUSE
  ACCOUNTING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  INVITED
}

enum BusinessType {
  SMALL_STORE
  BEAUTY_SALON
  BARBERSHOP
  MINIMARKET
  GROCERY
  TIRE_SHOP
  AUTO_PARTS
  HARDWARE_STORE
  CLOTHING_STORE
  PHONE_STORE
  COSMETICS_STORE
  SERVICE_BUSINESS
  OTHER
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DISABLE
}

enum Currency {
  DOP
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT
}

enum DocumentType {
  INTERNAL_RECEIPT
  CONSUMER_INVOICE
  FISCAL_INVOICE
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
}

enum CategoryType {
  PRODUCT
  SERVICE
  BOTH
}

enum InventoryMovementType {
  MANUAL_ENTRY
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  VOID_SALE_IN
  SALE_OUT
  PURCHASE_IN
}

enum InventoryTransferStatus {
  COMPLETED
  CANCELLED
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum CustomerDocumentType {
  CEDULA
  RNC
  PASSPORT
  NONE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum TaxpayerType {
  FINAL_CONSUMER
  FISCAL_CONSUMER
  GOVERNMENT
  SPECIAL_REGIME
  NONE
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum SaleItemType {
  PRODUCT
  SERVICE
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  OPENING
  SALE_CASH_IN
  MANUAL_IN
  MANUAL_OUT
  SALE_CANCELLED_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum InternalDocumentType {
  RECEIPT
  INTERNAL_INVOICE
}

enum InternalDocumentStatus {
  ISSUED
  VOIDED
}

enum FiscalEnvironment {
  SANDBOX
  PRODUCTION
}

enum FiscalProviderMode {
  MOCK
  PROVIDER
}

enum FiscalProviderStatus {
  ACTIVE
  INACTIVE
}

enum ElectronicInvoiceStatus {
  DRAFT
  PENDING_PROVIDER
  SENT
  ACCEPTED
  REJECTED
  FAILED
  CANCELLED
}

enum ElectronicDocumentType {
  E31
  E32
  E33
  E34
  E41
  E43
  E44
  E45
  INTERNAL_TEST
}

enum PlatformRole {
  SUPER_ADMIN
  SUPPORT_ADMIN
  BILLING_ADMIN
  AUDITOR
}

enum PlatformUserStatus {
  ACTIVE
  INACTIVE
}

enum SaasBillingInterval {
  MONTHLY
  YEARLY
}

enum CompanySubscriptionStatus {
  TRIAL
  ACTIVE
  PAYMENT_DUE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
}

enum SubscriptionPaymentMethod {
  CASH
  BANK_TRANSFER
  CARD_MANUAL
  CHECK
  OTHER
}

enum SubscriptionEventType {
  PLAN_ASSIGNED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  PAYMENT_REGISTERED
  NEXT_PAYMENT_DATE_UPDATED
  SUBSCRIPTION_GRACE_STARTED
  COMPANY_AUTO_SUSPENDED_FOR_NON_PAYMENT
  COMPANY_REACTIVATED_AFTER_PAYMENT
  BILLING_OVERDUE_PROCESS_RUN
  INVOICE_CREATED
  INVOICE_PAID
  INVOICE_PARTIALLY_PAID
  INVOICE_OVERDUE
  INVOICE_VOIDED
}

enum SubscriptionInvoiceStatus {
  DRAFT
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
  VOIDED
  CANCELLED
}

enum SubscriptionPaymentLinkStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAID
}

enum SubscriptionPaymentReportStatus {
  REPORTED
  REVIEWED
  DISCARDED
}

enum ProductCompatibilityGroupStatus {
  ACTIVE
  INACTIVE
}

enum ProductAlternativeCodeType {
  OEM
  MANUFACTURER
  REPLACEMENT
  OLD_CODE
  BARCODE
  OTHER
}

enum ProductSubstituteType {
  EQUIVALENT
  SUBSTITUTE
  UPGRADE
  DOWNGRADE
  RELATED
}

model Company {
  id                         String                          @id @default(cuid())
  name                       String
  legalName                  String?
  rncOrCedula                String?                         @unique
  phone                      String?
  email                      String?
  address                    String?
  logoUrl                    String?
  logoFileKey                String?
  logoUpdatedAt              DateTime?
  businessType               BusinessType
  status                     CompanyStatus                   @default(ACTIVE)
  branches                   Branch[]
  userBranchMemberships      UserBranchMembership[]
  users                      User[]
  roles                      Role[]
  settings                   BusinessSettings?
  auditLogs                  AuditLog[]
  categories                 Category[]
  brands                     Brand[]
  units                      Unit[]
  products                   Product[]
  services                   Service[]
  customers                  Customer[]
  sales                      Sale[]
  saleItems                  SaleItem[]
  payments                   Payment[]
  internalDocuments          InternalDocument[]
  internalDocumentItems      InternalDocumentItem[]
  documentSequences          DocumentSequence[]
  fiscalSettings             FiscalSettings?
  fiscalProviders            FiscalProvider[]
  fiscalCredentials          FiscalProviderCredential[]
  electronicInvoices         ElectronicInvoice[]
  electronicEvents           ElectronicInvoiceEvent[]
  fiscalErrors               FiscalError[]
  cashSessions               CashSession[]
  cashMovements              CashMovement[]
  inventoryMovements         InventoryMovement[]
  productBranchStocks        ProductBranchStock[]
  inventoryTransfers         InventoryTransfer[]
  inventoryTransferItems     InventoryTransferItem[]
  subscription               CompanySubscription?
  subscriptionPayments       SubscriptionPayment[]
  subscriptionEvents         SubscriptionEvent[]
  subscriptionInvoices       SubscriptionInvoice[]
  subscriptionPaymentLinks   SubscriptionPaymentLink[]
  subscriptionPaymentReports SubscriptionPaymentReport[]
  productCompatibilityGroups ProductCompatibilityGroup[]
  productCompatibilityItems  ProductCompatibilityGroupItem[]
  productAlternativeCodes    ProductAlternativeCode[]
  productSubstitutes         ProductSubstitute[]
  createdAt                  DateTime                        @default(now())
  updatedAt                  DateTime                        @updatedAt
  deletedAt                  DateTime?

  @@map("companies")
}

model Branch {
  id                  String                 @id @default(cuid())
  companyId           String
  name                String
  code                String
  phone               String?
  email               String?
  address             String?
  city                String?
  province            String?
  isMain              Boolean                @default(false)
  status              BranchStatus           @default(ACTIVE)
  company             Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  users               User[]
  userMemberships     UserBranchMembership[]
  auditLogs           AuditLog[]
  sales               Sale[]
  internalDocuments   InternalDocument[]
  documentSequences   DocumentSequence[]
  electronicInvoices  ElectronicInvoice[]
  cashSessions        CashSession[]
  cashMovements       CashMovement[]
  inventoryMovements  InventoryMovement[]
  productBranchStocks ProductBranchStock[]
  transfersFrom       InventoryTransfer[]    @relation("InventoryTransferFromBranch")
  transfersTo         InventoryTransfer[]    @relation("InventoryTransferToBranch")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("branches")
}

model User {
  id                        String                 @id @default(cuid())
  companyId                 String
  branchId                  String?
  roleId                    String
  name                      String
  email                     String                 @unique
  passwordHash              String
  phone                     String?
  status                    UserStatus             @default(ACTIVE)
  lastLoginAt               DateTime?
  company                   Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch                    Branch?                @relation(fields: [branchId], references: [id], onDelete: SetNull)
  branchMemberships         UserBranchMembership[]
  role                      Role                   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  sessions                  UserSession[]
  auditLogs                 AuditLog[]
  salesCreated              Sale[]                 @relation("SaleCreatedBy")
  salesCancelled            Sale[]                 @relation("SaleCancelledBy")
  internalDocumentsCreated  InternalDocument[]     @relation("InternalDocumentCreatedBy")
  internalDocumentsVoided   InternalDocument[]     @relation("InternalDocumentVoidedBy")
  electronicInvoicesCreated ElectronicInvoice[]    @relation("ElectronicInvoiceCreatedBy")
  paymentsCreated           Payment[]              @relation("PaymentCreatedBy")
  cashSessionsOpened        CashSession[]          @relation("CashSessionOpenedBy")
  cashSessionsClosed        CashSession[]          @relation("CashSessionClosedBy")
  cashMovementsCreated      CashMovement[]         @relation("CashMovementCreatedBy")
  inventoryMovementsCreated InventoryMovement[]    @relation("InventoryMovementCreatedBy")
  inventoryTransfersCreated InventoryTransfer[]    @relation("InventoryTransferCreatedBy")
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  deletedAt                 DateTime?

  @@index([companyId, status])
  @@index([companyId, branchId])
  @@map("users")
}

model UserBranchMembership {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  branchId  String
  isDefault Boolean  @default(false)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, branchId])
  @@index([companyId, userId, isDefault])
  @@index([companyId, branchId])
  @@map("user_branch_memberships")
}

model Role {
  id              String           @id @default(cuid())
  companyId       String
  name            String
  code            UserRole
  description     String?
  isSystem        Boolean          @default(true)
  isActive        Boolean          @default(true)
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  module          String
  action          PermissionAction
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserSession {
  id               String    @id
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, revokedAt])
  @@map("user_sessions")
}

model BusinessSettings {
  id                       String          @id @default(cuid())
  companyId                String          @unique
  currency                 Currency        @default(DOP)
  taxRate                  Decimal         @default(18) @db.Decimal(5, 2)
  allowNegativeStock       Boolean         @default(false)
  requireOpenCashForSales  Boolean         @default(true)
  defaultDocumentType      DocumentType    @default(INTERNAL_RECEIPT)
  defaultPaymentMethod     PaymentMethod   @default(CASH)
  enabledPaymentMethods    PaymentMethod[] @default([CASH, CARD, TRANSFER])
  receiptFooterText        String?
  printLogo                Boolean         @default(true)
  posQuickSaleMode         Boolean         @default(false)
  posShowStock             Boolean         @default(true)
  posAllowDiscounts        Boolean         @default(true)
  cashRequireOpeningAmount Boolean         @default(true)
  cashAllowExpenses        Boolean         @default(true)
  onboardingCompleted      Boolean         @default(false)
  onboardingCompletedAt    DateTime?
  company                  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@map("business_settings")
}

model AuditLog {
  id           String   @id @default(cuid())
  companyId    String
  branchId     String?
  userId       String?
  action       String
  module       String
  entityType   String?
  entityId     String?
  description  String
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, userId])
  @@map("audit_logs")
}

model Category {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  type        CategoryType
  description String?
  status      CatalogStatus @default(ACTIVE)
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products    Product[]
  services    Service[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@index([companyId, status, name])
  @@map("categories")
}

model Brand {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      CatalogStatus @default(ACTIVE)
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@index([companyId, status, name])
  @@map("brands")
}

model Unit {
  id             String        @id @default(cuid())
  companyId      String
  name           String
  code           String
  allowsDecimals Boolean       @default(false)
  status         CatalogStatus @default(ACTIVE)
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products       Product[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([companyId, code])
  @@unique([companyId, name])
  @@index([companyId, status, name])
  @@map("units")
}

model Product {
  id                     String                          @id @default(cuid())
  companyId              String
  categoryId             String?
  brandId                String?
  unitId                 String?
  name                   String
  description            String?
  sku                    String?
  barcode                String?
  cost                   Decimal                         @default(0) @db.Decimal(12, 2)
  price                  Decimal                         @default(0) @db.Decimal(12, 2)
  taxRate                Decimal                         @default(18) @db.Decimal(5, 2)
  stock                  Decimal                         @default(0) @db.Decimal(14, 3)
  minStock               Decimal                         @default(0) @db.Decimal(14, 3)
  trackInventory         Boolean                         @default(true)
  allowDiscount          Boolean                         @default(true)
  imageUrl               String?
  status                 CatalogStatus                   @default(ACTIVE)
  company                Company                         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category               Category?                       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand                  Brand?                          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unit                   Unit?                           @relation(fields: [unitId], references: [id], onDelete: SetNull)
  saleItems              SaleItem[]
  internalDocumentItems  InternalDocumentItem[]
  inventoryMovements     InventoryMovement[]
  branchStocks           ProductBranchStock[]
  inventoryTransferItems InventoryTransferItem[]
  compatibilityGroups    ProductCompatibilityGroupItem[]
  alternativeCodes       ProductAlternativeCode[]
  substitutes            ProductSubstitute[]             @relation("ProductSubstitutes")
  substituteFor          ProductSubstitute[]             @relation("SubstituteProducts")
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  deletedAt              DateTime?

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId, status, name])
  @@index([companyId, categoryId])
  @@index([companyId, brandId])
  @@map("products")
}

model ProductCompatibilityGroup {
  id          String                          @id @default(cuid())
  companyId   String
  name        String
  code        String
  description String?
  status      ProductCompatibilityGroupStatus @default(ACTIVE)
  company     Company                         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products    ProductCompatibilityGroupItem[]
  createdAt   DateTime                        @default(now())
  updatedAt   DateTime                        @updatedAt

  @@unique([companyId, code])
  @@index([companyId, status, name])
  @@map("product_compatibility_groups")
}

model ProductCompatibilityGroupItem {
  id        String                    @id @default(cuid())
  companyId String
  groupId   String
  productId String
  company   Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  group     ProductCompatibilityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  product   Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime                  @default(now())

  @@unique([groupId, productId])
  @@index([companyId])
  @@index([productId])
  @@map("product_compatibility_group_items")
}

model ProductAlternativeCode {
  id        String                     @id @default(cuid())
  companyId String
  productId String
  code      String
  type      ProductAlternativeCodeType @default(OTHER)
  company   Company                    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  product   Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@index([productId])
  @@map("product_alternative_codes")
}

model ProductSubstitute {
  id                  String                @id @default(cuid())
  companyId           String
  productId           String
  substituteProductId String
  type                ProductSubstituteType @default(SUBSTITUTE)
  notes               String?
  isBidirectional     Boolean               @default(true)
  priority            Int                   @default(0)
  company             Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  product             Product               @relation("ProductSubstitutes", fields: [productId], references: [id], onDelete: Cascade)
  substituteProduct   Product               @relation("SubstituteProducts", fields: [substituteProductId], references: [id], onDelete: Cascade)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([companyId, productId, substituteProductId])
  @@index([companyId])
  @@index([productId])
  @@index([substituteProductId])
  @@map("product_substitutes")
}

model Service {
  id                    String                 @id @default(cuid())
  companyId             String
  categoryId            String?
  name                  String
  description           String?
  price                 Decimal                @default(0) @db.Decimal(12, 2)
  taxRate               Decimal                @default(18) @db.Decimal(5, 2)
  durationMinutes       Int?
  allowDiscount         Boolean                @default(true)
  status                CatalogStatus          @default(ACTIVE)
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category              Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  saleItems             SaleItem[]
  internalDocumentItems InternalDocumentItem[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?

  @@index([companyId, status, name])
  @@index([companyId, categoryId])
  @@map("services")
}

model Customer {
  id                 String               @id @default(cuid())
  companyId          String
  type               CustomerType
  name               String
  commercialName     String?
  documentType       CustomerDocumentType
  documentNumber     String?
  email              String?
  phone              String?
  mobile             String?
  address            String?
  city               String?
  province           String?
  country            String?
  taxpayerType       TaxpayerType
  paymentTermsDays   Int                  @default(0)
  creditLimit        Decimal              @default(0) @db.Decimal(12, 2)
  notes              String?
  status             CustomerStatus       @default(ACTIVE)
  company            Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sales              Sale[]
  internalDocuments  InternalDocument[]
  electronicInvoices ElectronicInvoice[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?

  @@unique([companyId, documentNumber])
  @@index([companyId, status, name])
  @@index([companyId, type, name])
  @@map("customers")
}

model Sale {
  id                 String              @id @default(cuid())
  companyId          String
  branchId           String
  customerId         String?
  cashSessionId      String?
  saleNumber         String
  status             SaleStatus          @default(COMPLETED)
  subtotal           Decimal             @db.Decimal(12, 2)
  taxTotal           Decimal             @db.Decimal(12, 2)
  discountTotal      Decimal             @db.Decimal(12, 2)
  total              Decimal             @db.Decimal(12, 2)
  paidTotal          Decimal             @db.Decimal(12, 2)
  balanceDue         Decimal             @db.Decimal(12, 2)
  notes              String?
  createdById        String
  cancelledById      String?
  cancelledAt        DateTime?
  cancelReason       String?
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashSession        CashSession?        @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  createdBy          User                @relation("SaleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  cancelledBy        User?               @relation("SaleCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  items              SaleItem[]
  payments           Payment[]
  cashMovements      CashMovement[]
  internalDocuments  InternalDocument[]
  electronicInvoices ElectronicInvoice[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([companyId, saleNumber])
  @@index([companyId, status, createdAt(sort: Desc)])
  @@index([companyId, customerId, createdAt(sort: Desc)])
  @@index([companyId, branchId, createdAt(sort: Desc)])
  @@index([companyId, cashSessionId, createdAt(sort: Desc)])
  @@map("sales")
}

model SaleItem {
  id                    String                 @id @default(cuid())
  companyId             String
  saleId                String
  itemType              SaleItemType
  productId             String?
  serviceId             String?
  name                  String
  description           String?
  quantity              Decimal                @db.Decimal(14, 3)
  unitPrice             Decimal                @db.Decimal(12, 2)
  taxRate               Decimal                @db.Decimal(5, 2)
  discountAmount        Decimal                @db.Decimal(12, 2)
  subtotal              Decimal                @db.Decimal(12, 2)
  taxTotal              Decimal                @db.Decimal(12, 2)
  total                 Decimal                @db.Decimal(12, 2)
  affectsInventory      Boolean                @default(false)
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sale                  Sale                   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  internalDocumentItems InternalDocumentItem[]
  product               Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  service               Service?               @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  createdAt             DateTime               @default(now())

  @@index([companyId, saleId])
  @@index([companyId, productId])
  @@index([companyId, serviceId])
  @@map("sale_items")
}

model Payment {
  id            String        @id @default(cuid())
  companyId     String
  saleId        String
  cashSessionId String?
  method        PaymentMethod
  amount        Decimal       @db.Decimal(12, 2)
  reference     String?
  notes         String?
  createdById   String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  cashSession   CashSession?  @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  createdBy     User          @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime      @default(now())

  @@index([companyId, saleId])
  @@index([companyId, method, createdAt(sort: Desc)])
  @@index([companyId, cashSessionId, createdAt(sort: Desc)])
  @@map("payments")
}

model InternalDocument {
  id                 String                 @id @default(cuid())
  companyId          String
  branchId           String
  saleId             String
  customerId         String?
  documentNumber     String
  documentType       InternalDocumentType
  status             InternalDocumentStatus @default(ISSUED)
  subtotal           Decimal                @db.Decimal(12, 2)
  taxTotal           Decimal                @db.Decimal(12, 2)
  discountTotal      Decimal                @db.Decimal(12, 2)
  total              Decimal                @db.Decimal(12, 2)
  paidTotal          Decimal                @db.Decimal(12, 2)
  balanceDue         Decimal                @db.Decimal(12, 2)
  notes              String?
  createdById        String
  voidedById         String?
  voidedAt           DateTime?
  voidReason         String?
  company            Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch             Branch                 @relation(fields: [branchId], references: [id], onDelete: Restrict)
  sale               Sale                   @relation(fields: [saleId], references: [id], onDelete: Restrict)
  customer           Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy          User                   @relation("InternalDocumentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  voidedBy           User?                  @relation("InternalDocumentVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
