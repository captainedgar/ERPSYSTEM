NODE_ENV=development
DATABASE_URL=postgresql://comercia:comercia_dev_password@localhost:5433/comercia_erp?schema=public
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
JWT_SECRET=change_me_with_at_least_32_characters
JWT_REFRESH_SECRET=change_me_with_another_32_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
# PayPal Checkout hosted (never store PAN/CVV)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001
PAYPAL_CHECKOUT_CURRENCY=USD
PAYPAL_DOP_USD_RATE=58.50
# Update PAYPAL_DOP_USD_RATE administratively before operating PayPal Sandbox.
# Live payments are intentionally disabled in this phase.
