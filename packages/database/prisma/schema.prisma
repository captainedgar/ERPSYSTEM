generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  CASHIER
  SELLER
  WAREHOUSE
  ACCOUNTING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  INVITED
}

enum BusinessType {
  SMALL_STORE
  BEAUTY_SALON
  BARBERSHOP
  MINIMARKET
  GROCERY
  TIRE_SHOP
  AUTO_PARTS
  HARDWARE_STORE
  CLOTHING_STORE
  PHONE_STORE
  COSMETICS_STORE
  SERVICE_BUSINESS
  OTHER
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
}

enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DISABLE
}

enum Currency {
  DOP
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT
}

enum DocumentType {
  INTERNAL_RECEIPT
  CONSUMER_INVOICE
  FISCAL_INVOICE
}

enum CatalogStatus {
  ACTIVE
  INACTIVE
}

enum CategoryType {
  PRODUCT
  SERVICE
  BOTH
}

enum InventoryMovementType {
  MANUAL_ENTRY
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  VOID_SALE_IN
  SALE_OUT
  PURCHASE_IN
}

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum CustomerDocumentType {
  CEDULA
  RNC
  PASSPORT
  NONE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum TaxpayerType {
  FINAL_CONSUMER
  FISCAL_CONSUMER
  GOVERNMENT
  SPECIAL_REGIME
  NONE
}

model Company {
  id                 String              @id @default(cuid())
  name               String
  legalName          String?
  rncOrCedula        String?             @unique
  phone              String?
  email              String?
  address            String?
  logoUrl            String?
  businessType       BusinessType
  status             CompanyStatus       @default(ACTIVE)
  branches           Branch[]
  users              User[]
  roles              Role[]
  settings           BusinessSettings?
  auditLogs          AuditLog[]
  categories         Category[]
  brands             Brand[]
  units              Unit[]
  products           Product[]
  services           Service[]
  customers          Customer[]
  inventoryMovements InventoryMovement[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@map("companies")
}

model Branch {
  id                 String              @id @default(cuid())
  companyId          String
  name               String
  code               String
  phone              String?
  address            String?
  isMain             Boolean             @default(false)
  status             BranchStatus        @default(ACTIVE)
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  users              User[]
  auditLogs          AuditLog[]
  inventoryMovements InventoryMovement[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("branches")
}

model User {
  id                        String              @id @default(cuid())
  companyId                 String
  branchId                  String?
  roleId                    String
  name                      String
  email                     String              @unique
  passwordHash              String
  phone                     String?
  status                    UserStatus          @default(ACTIVE)
  lastLoginAt               DateTime?
  company                   Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch                    Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role                      Role                @relation(fields: [roleId], references: [id], onDelete: Restrict)
  sessions                  UserSession[]
  auditLogs                 AuditLog[]
  inventoryMovementsCreated InventoryMovement[] @relation("InventoryMovementCreatedBy")
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  deletedAt                 DateTime?

  @@index([companyId, status])
  @@index([companyId, branchId])
  @@map("users")
}

model Role {
  id              String           @id @default(cuid())
  companyId       String
  name            String
  code            UserRole
  description     String?
  isSystem        Boolean          @default(true)
  isActive        Boolean          @default(true)
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  module          String
  action          PermissionAction
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserSession {
  id               String    @id
  userId           String
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, revokedAt])
  @@map("user_sessions")
}

model BusinessSettings {
  id                       String          @id @default(cuid())
  companyId                String          @unique
  currency                 Currency        @default(DOP)
  taxRate                  Decimal         @default(18) @db.Decimal(5, 2)
  allowNegativeStock       Boolean         @default(false)
  requireOpenCashForSales  Boolean         @default(true)
  defaultDocumentType      DocumentType    @default(INTERNAL_RECEIPT)
  defaultPaymentMethod     PaymentMethod   @default(CASH)
  enabledPaymentMethods    PaymentMethod[] @default([CASH, CARD, TRANSFER])
  receiptFooterText        String?
  printLogo                Boolean         @default(true)
  posQuickSaleMode         Boolean         @default(false)
  posShowStock             Boolean         @default(true)
  posAllowDiscounts        Boolean         @default(true)
  cashRequireOpeningAmount Boolean         @default(true)
  cashAllowExpenses        Boolean         @default(true)
  onboardingCompleted      Boolean         @default(false)
  onboardingCompletedAt    DateTime?
  company                  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@map("business_settings")
}

model AuditLog {
  id           String   @id @default(cuid())
  companyId    String
  branchId     String?
  userId       String?
  action       String
  module       String
  entityType   String?
  entityId     String?
  description  String
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([companyId, userId])
  @@map("audit_logs")
}

model Category {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  type        CategoryType
  description String?
  status      CatalogStatus @default(ACTIVE)
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products    Product[]
  services    Service[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@index([companyId, status, name])
  @@map("categories")
}

model Brand {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      CatalogStatus @default(ACTIVE)
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products    Product[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@unique([companyId, name])
  @@index([companyId, status, name])
  @@map("brands")
}

model Unit {
  id             String        @id @default(cuid())
  companyId      String
  name           String
  code           String
  allowsDecimals Boolean       @default(false)
  status         CatalogStatus @default(ACTIVE)
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  products       Product[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([companyId, code])
  @@unique([companyId, name])
  @@index([companyId, status, name])
  @@map("units")
}

model Product {
  id                 String              @id @default(cuid())
  companyId          String
  categoryId         String?
  brandId            String?
  unitId             String?
  name               String
  description        String?
  sku                String?
  barcode            String?
  cost               Decimal             @default(0) @db.Decimal(12, 2)
  price              Decimal             @default(0) @db.Decimal(12, 2)
  taxRate            Decimal             @default(18) @db.Decimal(5, 2)
  stock              Decimal             @default(0) @db.Decimal(14, 3)
  minStock           Decimal             @default(0) @db.Decimal(14, 3)
  trackInventory     Boolean             @default(true)
  allowDiscount      Boolean             @default(true)
  imageUrl           String?
  status             CatalogStatus       @default(ACTIVE)
  company            Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category           Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand              Brand?              @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unit               Unit?               @relation(fields: [unitId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@index([companyId, status, name])
  @@index([companyId, categoryId])
  @@index([companyId, brandId])
  @@map("products")
}

model Service {
  id              String        @id @default(cuid())
  companyId       String
  categoryId      String?
  name            String
  description     String?
  price           Decimal       @default(0) @db.Decimal(12, 2)
  taxRate         Decimal       @default(18) @db.Decimal(5, 2)
  durationMinutes Int?
  allowDiscount   Boolean       @default(true)
  status          CatalogStatus @default(ACTIVE)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([companyId, status, name])
  @@index([companyId, categoryId])
  @@map("services")
}

model Customer {
  id               String               @id @default(cuid())
  companyId        String
  type             CustomerType
  name             String
  commercialName   String?
  documentType     CustomerDocumentType
  documentNumber   String?
  email            String?
  phone            String?
  mobile           String?
  address          String?
  city             String?
  province         String?
  country          String?
  taxpayerType     TaxpayerType
  paymentTermsDays Int                  @default(0)
  creditLimit      Decimal              @default(0) @db.Decimal(12, 2)
  notes            String?
  status           CustomerStatus       @default(ACTIVE)
  company          Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?

  @@unique([companyId, documentNumber])
  @@index([companyId, status, name])
  @@index([companyId, type, name])
  @@map("customers")
}

model InventoryMovement {
  id            String                @id @default(cuid())
  companyId     String
  branchId      String
  productId     String
  type          InventoryMovementType
  quantity      Decimal               @db.Decimal(14, 3)
  unitCost      Decimal?              @db.Decimal(12, 2)
  previousStock Decimal               @db.Decimal(14, 3)
  newStock      Decimal               @db.Decimal(14, 3)
  reason        String
  referenceType String?
  referenceId   String?
  createdById   String
  company       Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  branch        Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product       Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy     User                  @relation("InventoryMovementCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime              @default(now())

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, branchId, createdAt(sort: Desc)])
  @@index([companyId, productId, createdAt(sort: Desc)])
  @@map("inventory_movements")
}
