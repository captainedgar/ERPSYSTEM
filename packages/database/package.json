{
  "name": "@comercia/database",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run db:generate && tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "test": "node --test",
    "db:generate": "node ./scripts/generate-prisma.mjs",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:validate": "dotenv -e ../../.env -- prisma validate",
    "db:format": "dotenv -e ../../.env -- prisma format",
    "db:clear-sensitive": "dotenv -e ../../.env -- node ./scripts/clear-sensitive-data.mjs",
    "db:seed-platform-admin": "dotenv -e ../../.env -- node ./scripts/seed-platform-admin.mjs",
    "db:seed-saas-plans": "dotenv -e ../../.env -- node ./scripts/seed-saas-plans.mjs",
    "db:seed-demo": "dotenv -e ../../.env -- node ./scripts/seed-commercial-demo.mjs",
    "billing:process-overdue": "dotenv -e ../../.env -- node ./scripts/process-overdue-billing.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.0",
    "dotenv-cli": "^7.4.4",
    "effect": "3.21.0",
    "eslint": "^9.39.1",
    "prisma": "^6.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  }
}
